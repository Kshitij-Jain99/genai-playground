# ==================================================
# OTelScope AI — Environment Configuration
# ==================================================
#
# This file contains your local development configuration.
#
# Do NOT commit this file to Git.
# Commit only .env.example.
#
# ==================================================

# --------------------------------------------------
# Application
# --------------------------------------------------

APP_NAME="OTelScope AI"
APP_SERVICE_NAME=otelscope-ai-api
APP_ENVIRONMENT=development
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8001

# --------------------------------------------------
# Application logging
# --------------------------------------------------

APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json

# --------------------------------------------------
# OpenTelemetry resource identity
# --------------------------------------------------

OTEL_SERVICE_NAME=otelscope-ai-api

OTEL_RESOURCE_ATTRIBUTES=\
service.namespace=otelscope-ai,\
deployment.environment.name=development,\
service.version=0.1.0

# --------------------------------------------------
# OTLP exporter
# --------------------------------------------------

# Local self-hosted SigNoz OTLP HTTP endpoint

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_TIMEOUT=30000

# --------------------------------------------------
# OpenTelemetry signals
# --------------------------------------------------

OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# --------------------------------------------------
# Trace configuration
# --------------------------------------------------

OTEL_TRACES_SAMPLER=always_on
OTEL_PROPAGATORS=tracecontext,baggage

# --------------------------------------------------
# Metrics configuration
# --------------------------------------------------

OTEL_METRIC_EXPORT_INTERVAL=10000
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=delta

# --------------------------------------------------
# Python logging correlation
# --------------------------------------------------

OTEL_PYTHON_LOG_CORRELATION=true
OTEL_PYTHON_LOG_LEVEL=info

# --------------------------------------------------
# Simulated LLM configuration
# --------------------------------------------------

LLM_PROVIDER=simulated
LLM_MODEL=demo-model

# Keep empty while using the simulated provider.
# Add a real API key only when integrating an actual LLM.

LLM_API_KEY=

# --------------------------------------------------
# Simulated pricing
# (Used only for estimated-cost metrics)
# --------------------------------------------------

LLM_INPUT_COST_PER_1K_TOKENS=0.001
LLM_OUTPUT_COST_PER_1K_TOKENS=0.002
