# --------------------------------------------------
# Application configuration
# --------------------------------------------------

APP_NAME="OTelScope AI"
APP_SERVICE_NAME=otelscope-ai-api
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_HOST=127.0.0.1
APP_PORT=8001

LLM_PROVIDER=simulated
LLM_MODEL=demo-model

# --------------------------------------------------
# OpenTelemetry resource configuration
# --------------------------------------------------

OTEL_SERVICE_NAME=otelscope-ai-api
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0,deployment.environment.name=development,service.namespace=genai-observability

# --------------------------------------------------
# OpenTelemetry exporters
# --------------------------------------------------

OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# --------------------------------------------------
# Local self-hosted SigNoz
# --------------------------------------------------

OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --------------------------------------------------
# Trace configuration
# --------------------------------------------------

OTEL_PROPAGATORS=tracecontext,baggage
OTEL_TRACES_SAMPLER=parentbased_always_on